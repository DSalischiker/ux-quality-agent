VITE_AI_PROVIDER=gemini

VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

VITE_OPENROUTER_API_KEY=your_openrouter_api_key
VITE_OPENROUTER_MODEL=google/gemini-flash-1.5
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
VITE_OPENROUTER_HTTP_REFERER=http://localhost:5173
VITE_OPENROUTER_APP_NAME=ux-quality-agent

# Security note:
# Any VITE_* value is shipped to the browser bundle.
# For production, call the provider through a backend proxy and keep the real key server-side.
